# Cloudflare static-asset response headers.
# Docs: https://developers.cloudflare.com/workers/static-assets/headers/
#
# Content-Security-Policy — tightened (feat/csp-tighten).
# script-src/style-src no longer use 'unsafe-inline':
#   - All component CSS is emitted as external 'self' stylesheets
#     (astro.config.mjs build.inlineStylesheets: 'never').
#   - Syntax highlighting is disabled (build.markdown.syntaxHighlight: false)
#     so no inline style= remains on rendered code blocks.
#   - The six remaining inline <script> blocks (Astro-bundled, inlined) are
#     pinned by SHA-256 hash:
#       1. HelpModal open/close        (all pages)
#       2. landing terminal boot       (index.html only)
#       3. delegated copy-to-clipboard (BaseLayout pages)
#       4. SiteMenu open/close         (BaseLayout pages)
#       5. skills tab + pillar filter  (/skills/ only)
#       6. bundle tab switcher         (/bundles/ only)
#       7. JSON-LD Organization graph  (all pages, type=application/ld+json,
#          static bytes from src/components/Seo.astro — not executed, but
#          CSP script-src still applies to the <script> element)
#   - static.cloudflareinsights.com / cloudflareinsights.com are allowed for
#     Cloudflare Web Analytics (edge-injected beacon, not in source).
#
# NOTE: Cloudflare bot "JavaScript Detections" injects a per-load inline script
# whose body (and therefore SHA-256 hash) rotates on every request, so it cannot
# be pinned here. Keep that feature DISABLED (Security -> Bots) while this strict
# script-src is in force; the rest of bot protection (heuristics, Managed
# Challenge, WAF) does not inject page scripts and is unaffected.
#
# REGENERATING THE HASHES: these are SHA-256 of the exact inline <script> bodies
# in dist/client after `npm run build`. If you change any bundled script (or bump
# Astro/Vite, which can change the inlined wrapper), recompute and update them.
#   npm run build
#   # then hash each unique inline <script> body, e.g.:
#   printf '%s' '<exact script body>' | openssl dgst -sha256 -binary | openssl base64
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-RG2Vl9/CWuC4bLS0RKUEC98FHboSICAr9i2TuJ3w2Z4=' 'sha256-Ks1A/j5CFlpBMe0H8sBNQ2VBLJpMaui6bLBSYaorIlg=' 'sha256-o6syoIy/8TVskZPnPiYVhZ54gs6eixrEjsqxWx61PAE=' 'sha256-S8s+X/FJ4ibhybJfgQjbbBcRVuCbKYZDIibrDSD1Fog=' 'sha256-K3WQfIpq5i+nUZQlbYhqhnfF1V5tlfhW8w4hIHGDxu4=' 'sha256-2KVSZiRgqdRonyS5HJv4I6hG+Qxx62pZjisFjjM3JeM=' 'sha256-0luhRzwYBCNWM+bAZHyYyfEmlrY4A7B/kihyfIeWxMc=' https://static.cloudflareinsights.com; style-src 'self'; img-src 'self'; font-src 'self'; connect-src 'self' https://cloudflareinsights.com https://gate.quirgs.com https://quirgs-hitl-gate.elbrigante9.workers.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests

# RFC 9116 security contact — serve as plain text so scanners/parsers accept it.
/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8

# llms.txt — agent-facing site map (llmstxt.org). Plain text + CORS-readable so
# any LLM/agent can fetch it cross-origin. CSP on a text/plain response is inert.
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

# ARD (Agentic Resource Discovery) catalog — must be CORS-readable so any
# ARD-compliant crawler can fetch it cross-origin. JSON file only; this block
# does not touch the strict CSP pinned to /* (CSP on a JSON response is inert).
/.well-known/ai-catalog.json
  Access-Control-Allow-Origin: *
  Content-Type: application/json
  Cache-Control: public, max-age=3600

# Content provenance — machine-readable authority/limitation disclosure for agents.
# CORS-readable so any agent can fetch cross-origin. Mirrors ai-catalog.json pattern.
/.well-known/provenance.json
  Access-Control-Allow-Origin: *
  Content-Type: application/json
  Cache-Control: public, max-age=3600

# Agent discovery Link headers (RFC 8288) on the homepage — points agents at
# the ARD catalog and the agent-facing site map without requiring a page fetch.
/
  Link: </.well-known/ai-catalog.json>; rel="api-catalog"
  Link: </llms.txt>; rel="service-doc"

# Agent Skills Discovery index (RFC v0.2.0). Generated at build time by
# src/pages/.well-known/agent-skills/index.json.ts and [slug]/SKILL.md.ts —
# CORS-readable so any agent can fetch it cross-origin, mirroring the
# ai-catalog.json pattern above.
/.well-known/agent-skills/index.json
  Access-Control-Allow-Origin: *
  Content-Type: application/json
  Cache-Control: public, max-age=3600

/.well-known/agent-skills/*/SKILL.md
  Access-Control-Allow-Origin: *
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600

# RFC 9727 API catalog — linkset+json describing the two Workers APIs
# (registry-api, hitl-gate). CORS-readable, same pattern as above.
/.well-known/api-catalog
  Access-Control-Allow-Origin: *
  Content-Type: application/linkset+json
  Cache-Control: public, max-age=3600

# The one remaining legacy guide (ollama) is preserved verbatim with its own inline
# scripts/styles that must not be modified — so detach the strict /* CSP for it (the
# `!` prefix removes the /*-inherited header). This was a /guides/* wildcard until
# Track 2 migrated every other guide to managed MDX; those pages now correctly fall
# under the strict /* CSP (same BaseLayout inline-script surface as skills pages, all
# hash-pinned — MDX body content has no inline script/style).
#
# The pattern MUST be a prefix wildcard, not the exact `.html` path: Cloudflare serves
# this asset at BOTH /guides/ollama_anythingllm_guide.html AND the extensionless
# /guides/ollama_anythingllm_guide (auto .html resolution), plus ?utm= query forms.
# An exact-`.html` rule missed the extensionless URL, so the strict /* CSP applied
# there and blocked ollama's legacy inline scripts (regression fixed here). The
# trailing `*` covers every form; no MDX guide starts with this name, so they're
# unaffected.
#
# The Link line is a self-referencing canonical. Without it Google deduped the page
# against chatgpt.com and credited that domain. A <head> <link rel=canonical> also
# lives in the .html (feat #144); this HTTP header stays as a fallback. Both point at
# the clean URL. ollama stays a literal .html (top earner — migration plan).
/guides/ollama_anythingllm_guide*
  ! Content-Security-Policy
  Link: <https://quirgs.com/guides/ollama_anythingllm_guide.html>; rel="canonical"
