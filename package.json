    "seed:registry": "node scripts/seed-registry.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.6",
