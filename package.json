    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "^0.5.50",
    "astro": "^6.4.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "patch-package": "^8.0.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.103.0",
    "yaml": "^1.10.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
