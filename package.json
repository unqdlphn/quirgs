{
  "name": "quirgs",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "postinstall": "patch-package",
    "test": "npm run test:registry && npm run test:hitl && npm run test:metrics",
    "test:registry": "vitest run --config workers/registry-api/vitest.config.js",
    "test:hitl": "vitest run --config workers/hitl-gate/vitest.config.js",
    "test:metrics": "vitest run --config workers/metrics-api/vitest.config.js",
    "seed:registry": "node scripts/seed-registry.mjs",
    "check:integrity": "node scripts/check-live-integrity.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.4",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^5.0.6",
    "@astrojs/sitemap": "^3.7.3",
    "@keystatic/astro": "^5.2.0",
    "@keystatic/core": "^0.5.50",
    "astro": "^7.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "patch-package": "^8.0.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.113.0",
    "yaml": "^1.10.3"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "sharp": "^0.35.0",
    "vite": "^8.0.13"
  }
}
