---
// src/pages/support.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBlock from "../components/NavBlock.astro";
---

<BaseLayout
  title="Support | Quirgs"
  description="How to get help with Quirgs AI governance skills."
  terminalPath="~/support"
>
  <NavBlock currentPath="/" />

  <div class="line">
    <span class="prompt">admin@quirgs</span><span class="path">~/support</span
    ><span class="text-bright">$</span>&nbsp;cat support.md
  </div>
  <div class="line">&nbsp;</div>

  <div class="detail-header">
    <h1 class="text-bright">Support</h1>
    <p class="tagline">Get help with installing or using a Quirgs skill.</p>
  </div>

  <div class="line">
    <span class="label">PRIMARY SUPPORT</span>
  </div>
  <div class="line">
    GitHub Issues &rarr; <a href="https://github.com/unqdlphn/quirgs/issues" target="_blank" rel="noopener">github.com/unqdlphn/quirgs/issues</a>
  </div>
  <div class="line">&nbsp;</div>

  <div class="line">Use GitHub Issues for:</div>
  <div class="line">&nbsp;&nbsp;Bug reports on the site or skills</div>
  <div class="line">&nbsp;&nbsp;Skill feedback and improvement requests</div>
  <div class="line">&nbsp;&nbsp;Questions about the compliance bundle</div>
  <div class="line">&nbsp;&nbsp;Feature suggestions</div>
  <div class="line">&nbsp;</div>

  <div class="line">
    <span class="label">COMMUNITY + ANNOUNCEMENTS</span>
  </div>
  <div class="line">
    X (Twitter) &rarr; <a href="https://x.com/QuirgsAI" target="_blank" rel="noopener">x.com/QuirgsAI</a>
  </div>
  <div class="line">&nbsp;</div>

  <div class="line">
    For general questions, governance discussions, and Quirgs news &mdash;
    follow and mention <span class="text-bright">@QuirgsAI</span>.
  </div>

  <div class="line">&nbsp;</div>
  <div>
    See also: <a href="/skills/">/skills/</a> &middot; <a href="/bundle/">/bundle/</a>
  </div>
</BaseLayout>
