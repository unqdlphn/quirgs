---
// src/pages/support.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBlock from "../components/NavBlock.astro";
---

<BaseLayout
  title="Support | Quirgs"
  description="How to get help with Quirgs AI governance skills."
  terminalPath="~/support"
>
  <NavBlock currentPath="/support/" />

  <div class="line">
    <span class="prompt">admin@quirgs</span><span class="path">~/support</span
    ><span class="text-bright">$</span>&nbsp;cat support.md
  </div>
  <div class="line">&nbsp;</div>

  <div class="detail-header">
    <h1 class="text-bright">Support</h1>
    <p class="line">Get help with installing or using a Quirgs skill.</p>
  </div>

  <div class="line">
    <span class="label">PRIMARY SUPPORT</span>
  </div>

  <div class="line">- Bug reports on the site or skills</div>
  <div class="line">- Skill feedback and improvement requests</div>
  <div class="line">- Questions about the compliance bundle</div>
  <div class="line">- Feature suggestions</div>
  <div class="line">- Early access to HITL Gate</div>
  <div class="line">- Request test tokens for HITL Gate</div>

  <div class="line">&nbsp;</div>

  <div>
    GitHub Issues &rarr; <a
      href="https://github.com/unqdlphn/quirgs/issues"
      target="_blank"
      rel="noopener">Open an Issue</a
    >
  </div>

  <div class="line">&nbsp;</div>

  <div>
    <h2 class="label">COMMUNITY + ANNOUNCEMENTS</h2>
    <div class="line">General questions, discussions, and Quirgs news.</div>
  </div>

  <div class="line">&nbsp;</div>

  <div>
    x.com &rarr; <a href="https://x.com/QuirgsAI" target="_blank" rel="noopener"
      >@QuirgsAI</a
    >
  </div>
  <div>&nbsp;</div>
  <div>
    Youtube &rarr; <a
      href="https://youtube.com/@quirgs"
      target="_blank"
      rel="noopener">@quirgs</a
    >
  </div>
  <div>&nbsp;</div>
  <div>
    Created by &rarr; <a
      href="https://torreyladams.com"
      target="_blank"
      rel="noopener">unqdlphn</a
    >
  </div>
</BaseLayout>
