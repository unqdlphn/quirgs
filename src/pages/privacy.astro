---
// src/pages/privacy.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBlock from "../components/NavBlock.astro";
---

<BaseLayout
  title="Privacy Policy | Quirgs"
  description="Privacy policy for the Quirgs AI governance skills registry."
  terminalPath="~/privacy"
>
  <NavBlock currentPath="/privacy/" />

  <div class="line">
    <span class="prompt">admin@quirgs</span><span class="path">~/privacy</span
    ><span class="text-bright">$</span>&nbsp;cat privacy.md
  </div>
  <div class="line">&nbsp;</div>

  <div class="detail-header">
    <h1 class="text-bright">Privacy Policy</h1>
    <p class="tagline">How we handle information on quirgs.com.</p>
  </div>

  <div class="archive-note">
    <strong class="text-yellow">[PLACEHOLDER]</strong>&nbsp; The full privacy
    policy is still being drafted. The site is a static registry of open-source
    AI governance skills and does not collect personal data or set tracking
    cookies. Cloudflare Web Analytics is in use. It collects anonymous,
    aggregated page view data. No cookies are set. No personally identifiable
    information is collected. Data is processed by Cloudflare, Inc.
  </div>

  <div class="line">&nbsp;</div>
  <div>
    Questions? See <a href="/support/">/support/</a>.
  </div>
</BaseLayout>
