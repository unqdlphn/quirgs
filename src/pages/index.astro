---
// src/pages/index.astro
import HelpModal from "../components/HelpModal.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover"
    />
    <title>Quirgs | AI Governance Skills</title>
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <style is:global>
      :root {
        --bg-color: #09090b;
        --term-bg: #18181b;
        --term-border: #27272a;
        --text-main: #a1a1aa;
        --text-bright: #f4f4f5;
        --accent-green: #4ade80;
        --accent-blue: #60a5fa;
        --accent-red: #f87171;
        --accent-yellow: #facc15;
      }

      body {
        background-color: var(--bg-color);
        color: var(--text-main);
        font-family: "JetBrains Mono", "Courier New", Courier, monospace;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh;
        min-height: 100dvh;
        margin: 0;
        padding: 20px;
        box-sizing: border-box;
      }

      .main-wrapper {
        width: 100%;
        max-width: 800px;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        margin: auto 0;
      }

      .logo {
        width: 96px;
        margin-top: 0;
        flex-shrink: 0;
      }

      .site-bottom-row {
        width: 100%;
        max-width: 800px;
        margin-top: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      @media (max-width: 600px) {
        .logo {
          width: 64px;
        }
        .site-bottom-row {
          margin-top: 16px;
          gap: 8px;
        }
      }

      .terminal-container {
        width: 100%;
        max-width: 800px;
        background-color: var(--term-bg);
        border: 1px solid var(--term-border);
        border-radius: 8px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 120px);
        max-height: calc(100dvh - 120px);
      }

      .terminal-header {
        background-color: #09090b;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--term-border);
      }

      .mac-btns {
        display: flex;
        gap: 8px;
      }

      .mac-btn {
        width: 12px;
        height: 12px;
        border-radius: 50%;
      }

      .close {
        background-color: #ff5f56;
      }

      .minimize {
        background-color: #ffbd2e;
      }

      .maximize {
        background-color: #27c93f;
      }

      .terminal-title {
        flex-grow: 1;
        text-align: center;
        color: #71717a;
        font-size: 0.85rem;
      }

      .help-trigger {
        background: transparent;
        border: 1px solid var(--term-border);
        color: #71717a;
        font-family: "JetBrains Mono", "Courier New", Courier, monospace;
        font-size: 0.75rem;
        padding: 2px 6px;
        cursor: pointer;
        border-radius: 3px;
        transition:
          color 0.15s,
          border-color 0.15s;
        flex-shrink: 0;
        line-height: 1;
      }

      .help-trigger:hover {
        color: var(--accent-blue);
        border-color: var(--accent-blue);
      }

      .terminal-body {
        padding: 24px;
        font-size: 0.95rem;
        line-height: 1.6;
        min-height: min(400px, 60vh);
        min-height: min(400px, 60dvh);
        overflow-y: auto;
      }

      .line {
        margin-bottom: 8px;
        display: flex;
        flex-wrap: wrap;
      }

      .prompt {
        color: var(--accent-green);
        margin-right: 8px;
        font-weight: bold;
      }

      .path {
        color: var(--accent-blue);
        margin-right: 8px;
      }

      .text-red {
        color: var(--accent-red);
        margin-right: 0px;
      }

      .text-yellow {
        color: var(--accent-yellow);
        margin-right: 0px;
      }

      .text-blue {
        color: var(--accent-blue);
        margin-right: 0px;
      }

      .text-green {
        color: var(--accent-green);
        margin-right: 0px;
      }

      .text-bright {
        color: var(--text-bright);
        margin-right: 0px;
      }

      .cursor {
        display: inline-block;
        width: 10px;
        height: 1.2em;
        background-color: var(--text-bright);
        vertical-align: bottom;
        animation: blink 1s step-end infinite;
        margin-left: 2px;
      }

      .hidden {
        display: none;
      }

      a {
        color: var(--accent-blue);
        text-decoration: none;
        border-bottom: 1px dashed var(--accent-blue);
        transition:
          color 0.2s,
          border-color 0.2s;
      }

      a:hover {
        color: var(--accent-green);
        border-color: var(--accent-green);
      }

      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }

        50% {
          opacity: 0;
        }
      }
    </style>
  </head>

  <body>
    <div class="main-wrapper">
      <div class="terminal-container">
        <div class="terminal-header">
          <div class="mac-btns">
            <div class="mac-btn close"></div>
            <div class="mac-btn minimize"></div>
            <div class="mac-btn maximize"></div>
          </div>
          <div class="terminal-title">admin@quirgs: ~</div>
          <button
            id="help-open-btn"
            class="help-trigger"
            aria-label="Open help"
            title="How Quirgs works">[?]</button
          >
        </div>
        <div class="terminal-body" id="terminal">
          <!-- Content will be injected by JavaScript -->
        </div>
      </div>
      <div class="site-bottom-row">
        <Footer />
        <img src="/assets/logo.png" alt="Quirgs Logo" class="logo" />
      </div>
    </div>
    <HelpModal />

    <script>
      // Terminal text sequence
      const sequence = [
        { type: "input", text: "cat README.md" },
        { type: "blank", delay: 200 },
        {
          type: "output",
          text: '<span class="text-bright">Quirgs</span> — AI governance skills for teams building with AI.',
          delay: 400,
        },
        {
          type: "output",
          text: '<span class="text-green">Governance first. Build accordingly.</span>',
          delay: 300,
        },
        { type: "blank", delay: 200 },
        {
          type: "output",
          text: "7 production-validated compliance skills for Claude, Cowork, and the Anthropic ecosystem.",
          delay: 400,
        },
        {
          type: "output",
          text: "Classify risk. Gate decisions. Audit for standards. Stay transparent.",
          delay: 400,
        },
        { type: "blank", delay: 300 },
        {
          type: "output",
          text: '<span class="text-yellow">[ARCHIVE]&nbsp;</span> Legacy reference guides still available:&nbsp;<a href="guides/index.html">quirgs.com/guides</a>',
          delay: 0,
        },
        { type: "blank", delay: 500 },

        { type: "input", text: "ls -la /quirgs/skills/" },
        {
          type: "output",
          text: 'total 7&nbsp;&nbsp; <span class="text-bright">  AI Compliance Suite  ·  7 production-validated skills</span>',
          delay: 500,
        },
        { type: "blank", delay: 200 },
        {
          type: "output",
          text: '-rwxr--r--  <span class="text-blue" style="display:inline-block;min-width:26ch">ai-transparency-writer</span>  <span class="text-yellow">[skill.1]</span>',
          delay: 130,
        },
        {
          type: "output",
          text: '-rwxr--r--  <span class="text-blue" style="display:inline-block;min-width:26ch">eu-ai-act-classifier</span>  <span class="text-yellow">[skill.2]</span>',
          delay: 130,
        },
        {
          type: "output",
          text: '-rwxr--r--  <span class="text-blue" style="display:inline-block;min-width:26ch">hitl-compliance-gate</span>  <span class="text-yellow">[skill.3]</span>',
          delay: 130,
        },
        {
          type: "output",
          text: '-rwxr--r--  <span class="text-blue" style="display:inline-block;min-width:26ch">incident-response-logger</span>  <span class="text-yellow">[skill.4]</span>',
          delay: 130,
        },
        {
          type: "output",
          text: '-rwxr--r--  <span class="text-blue" style="display:inline-block;min-width:26ch">iso-42001-audit-prep</span>  <span class="text-yellow">[skill.5]</span>',
          delay: 130,
        },
        {
          type: "output",
          text: '-rwxr--r--  <span class="text-blue" style="display:inline-block;min-width:26ch">nist-ai-rmf-checkpoint</span>  <span class="text-yellow">[skill.6]</span>',
          delay: 130,
        },
        {
          type: "output",
          text: '-rwxr--r--  <span class="text-blue" style="display:inline-block;min-width:26ch">pii-exposure-checker</span>  <span class="text-yellow">[skill.7]</span>',
          delay: 130,
        },
        { type: "blank", delay: 500 },
        {
          type: "output",
          text: '<span class="text-yellow">[BUNDLE]&nbsp;</span> quirgs-compliance&nbsp;&nbsp;<span class="text-bright">All 7 skills ·</span>&nbsp;<a href="/bundle/">Install the full suite &rarr;</a>',
          delay: 300,
        },
        { type: "blank", delay: 400 },
        {
          type: "output",
          text: '<span class="text-bright">Browse:&nbsp;</span><a href="/skills/">/skills/</a>&nbsp;&nbsp;|&nbsp;&nbsp;<a href="/bundle/">/bundle/</a>&nbsp;&nbsp;|&nbsp;&nbsp;<a href="/guides/">/guides/</a>',
          delay: 500,
        },
        { type: "prompt-only" },
      ];

      const terminal = document.getElementById("terminal") as HTMLElement;
      let currentStep = 0;

      function getPromptHTML() {
        return `<span class="prompt">admin@quirgs</span><span class="path">~/system</span><span class="text-bright">$&nbsp;</span>`;
      }

      async function typeText(element: HTMLElement, text: string, speed = 30) {
        return new Promise<void>((resolve) => {
          let i = 0;
          // Temporarily remove HTML tags for typing effect, or just insert HTML directly if it contains tags
          if (text.includes("<span") || text.includes("<a")) {
            element.innerHTML += text;
            setTimeout(resolve, speed * 10);
          } else {
            function type() {
              if (i < text.length) {
                element.innerHTML += text.charAt(i);
                i++;
                setTimeout(type, speed);
              } else {
                resolve();
              }
            }
            type();
          }
        });
      }

      async function runSequence() {
        for (const step of sequence) {
          const line = document.createElement("div");
          line.className = "line";

          if (step.type === "input") {
            line.innerHTML = getPromptHTML();
            const textSpan = document.createElement("span");
            line.appendChild(textSpan);

            // Add cursor to current line
            const cursor = document.createElement("span");
            cursor.className = "cursor";
            line.appendChild(cursor);

            terminal.appendChild(line);

            await new Promise((r) => setTimeout(r, 600)); // Pause before typing
            await typeText(textSpan, step.text || "", 50);
            await new Promise((r) => setTimeout(r, 400)); // Pause after typing

            // Remove cursor
            line.removeChild(cursor);
          } else if (step.type === "output") {
            terminal.appendChild(line);
            await typeText(line, step.text || "", 0); // Fast output
          } else if (step.type === "blank") {
            line.innerHTML = "&nbsp;";
            terminal.appendChild(line);
          } else if (step.type === "prompt-only") {
            line.innerHTML = getPromptHTML();
            const cursor = document.createElement("span");
            cursor.className = "cursor";
            line.appendChild(cursor);
            terminal.appendChild(line);
          }

          // Scroll to bottom
          terminal.scrollTop = terminal.scrollHeight;

          // Wait for specified delay
          if (step.delay) {
            await new Promise((r) => setTimeout(r, step.delay));
          }
        }
      }

      // Start animation after a brief initial pause
      setTimeout(runSequence, 1000);
    </script>
  </body>
</html>
