---
// src/pages/guides/index.astro
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBlock from "../../components/NavBlock.astro";

// Net-new, Keystatic-managed MDX guides (clean /guides/<slug>/ URLs). Listed
// separately, above the legacy .html archive. Drafts are excluded; newest first.
const currentGuides = (await getCollection("guides"))
  .filter((entry) => entry.data.status !== "draft")
  .sort((a, b) => b.data.lastUpdated.valueOf() - a.data.lastUpdated.valueOf());

const legacyGuides = [
  { file: "ai_prompt_engineering.html", name: "AI Prompt Engineering" },
  {
    file: "copilot_commands_reference.html",
    name: "Copilot Commands Reference",
  },
  { file: "gemma_vs_gemini_guide.html", name: "Gemma vs Gemini" },
  { file: "ollama_anythingllm_guide.html", name: "Ollama + AnythingLLM" },
  { file: "taco_marketing_strategy.html", name: "T.A.C.O Marketing Strategy" },
];
---

<BaseLayout
  title="Guides | Quirgs"
  description="Reference guides from Quirgs — current MDX guides plus the preserved V1 archive."
  terminalPath="~/guides"
>
  <NavBlock currentPath="/guides/" />
  <div class="line">
    <span class="prompt">admin@quirgs</span><span class="path">~/guides</span
    ><span class="text-bright">$</span>&nbsp;ls -la /guides/
  </div>
  <div class="line">&nbsp;</div>

  {
    currentGuides.length > 0 && (
      <>
        <div class="line">
          <span class="text-green">[GUIDES]&nbsp;</span> Current
        </div>
        <div class="line">&nbsp;</div>
        {currentGuides.map((guide) => {
          const dir = `${guide.id}/`;
          return (
            <div class="line">
              &nbsp;
              <span>drwxr-xr-x guides </span>&nbsp;
              <a href={`/guides/${guide.id}/`}>{dir}</a>&nbsp;
              <span>{" ".repeat(Math.max(1, 34 - dir.length))}</span>
              <span>{guide.data.title}</span>
            </div>
          );
        })}
        <div class="line">&nbsp;</div>
      </>
    )
  }

  <div class="line">
    <span class="text-yellow">[ARCHIVE]&nbsp;</span> Legacy reference guides
  </div>
  <div class="line">&nbsp;</div>
  {
    legacyGuides.map((guide) => (
      <div class="line">
        &nbsp;
        <span>-rw-r--r-- guides </span>&nbsp;
        <a href={`/guides/${guide.file}`}>{guide.file}</a>&nbsp;
        <span>{" ".repeat(Math.max(1, 34 - guide.file.length))}</span>
        <span>{guide.name}</span>
      </div>
    ))
  }

  <div class="archive-note">
    <span class="text-yellow">[NOTE]</span> &rarr; These guides were published before
    Quirgs V2.<br />
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&rarr; They are preserved exactly as
    written — URLs and content unchanged.<br />
  </div>
</BaseLayout>
