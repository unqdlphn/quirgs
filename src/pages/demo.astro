---
// src/pages/demo.astro
// Fully static HITL Gate demo queue. No API calls, no Worker dependency, no D1
// reads, no TTL expiry risk. The three events are hardcoded in public/demo.js
// and rendered client-side into #demo-queue-container. Approve/Reject are
// interactive but only fire a client-side demo-mode message — never a fetch.
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBlock from "../components/NavBlock.astro";
---

<BaseLayout
  title="Demo Queue | Quirgs"
  description="See the Quirgs HITL Gate in action — a live demo review queue with realistic compliance events."
  terminalPath="~/demo"
>
  <NavBlock currentPath="/demo/" />

  <div class="line">
    <span class="prompt">admin@quirgs</span><span class="path">~/demo</span
    ><span class="text-bright">$</span>&nbsp;cat queue.md
  </div>
  <div class="line">&nbsp;</div>

  <div class="detail-header">
    <h1 class="text-bright">Demo Queue</h1>
    <p class="line">Pre-populated review queue — no credentials required.</p>
  </div>

  <div class="token-block">
    <div class="line"><span class="text-bright">[DEMO]</span></div>
    <div class="line">
      This is a demonstration queue with synthetic compliance events.
    </div>
    <div class="line">
      Approve and Reject are interactive — actions are not saved.
    </div>
  </div>

  <div class="line">&nbsp;</div>

  <div class="queue-block">
    <div class="line"><span class="text-bright">[QUEUE]</span></div>
    <div id="demo-queue-container">
      <div class="line">Loading demo queue...</div>
    </div>
  </div>

  <div class="line">&nbsp;</div>

  <div class="ctas-block">
    <div>
      &rarr; <a href="/hitl/">/hitl/</a> wire your own agent to the gate
    </div>
    <div class="line">&nbsp;</div>
    <div>
      &rarr; <a href="/review/">/review/</a> live queue (requires write token)
    </div>
    <div class="line">&nbsp;</div>
    <div>
      &rarr; <a href="/gate/">/gate/</a> what the gate is
    </div>
  </div>

  <div class="line">&nbsp;</div>

  <div class="line">
    <span class="prompt">admin@quirgs</span><span class="path">~/demo</span
    ><span class="text-bright">$&nbsp;</span><span class="cursor"></span>
  </div>
</BaseLayout>

<style is:global>
  /* Demo cards separate with a CSS rule instead of a glyph divider: the old
     "━"×39 run was a single unbreakable token wider than a phone viewport and
     overflowed horizontally. A border can never overflow. Scoped to the demo
     queue via #demo-queue-container so /review/ is untouched. Cards are injected
     by demo.js without Astro's scope hash, so this must be is:global. */
  #demo-queue-container .event-card {
    border-top: 1px solid var(--term-border);
    padding-top: 16px;
  }
</style>

<script src="/demo.js" defer></script>
