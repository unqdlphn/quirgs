---
// src/pages/bundle/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBlock from "../../components/NavBlock.astro";
---

<BaseLayout
  title="Quirgs Compliance Bundle | AI Governance Skills"
  description="7 production-validated AI compliance skills in one installable bundle. EU AI Act, NIST AI RMF, ISO 42001."
  terminalPath="~/install"
>
  <!-- Site navigation -->
  <NavBlock currentPath="/bundle/" />

  <!-- Main install sequence -->
  <div class="line">
    <span class="prompt">admin@quirgs</span><span class="path">~/install</span
    ><span class="text-bright">$</span>&nbsp;./get-bundle.sh quirgs-compliance
  </div>
  <div class="line">&nbsp;</div>
  <div class="line">
    <span class="text-bright">[FETCHING]</span>&nbsp;&nbsp;quirgs-compliance
    v1.0 (7 skills)
  </div>
  <div class="line bundle-contents">
    <span class="text-bright">[CONTENTS]</span>&nbsp;&nbsp;<span
      class="contents-list"
      ><a href="/skills/ai-transparency-writer">ai-transparency-writer</a><br
      /><a href="/skills/eu-ai-act-classifier">eu-ai-act-classifier</a><br /><a
        href="/skills/hitl-compliance-gate">hitl-compliance-gate</a
      ><br /><a href="/skills/incident-response-logger"
        >incident-response-logger</a
      ><br /><a href="/skills/iso-42001-audit-prep">iso-42001-audit-prep</a><br
      /><a href="/skills/nist-ai-rmf-checkpoint">nist-ai-rmf-checkpoint</a><br
      /><a href="/skills/pii-exposure-checker">pii-exposure-checker</a></span
    >
  </div>
  <div class="line">&nbsp;</div>
  <div class="install-block">
    <p class="install-cmd-row">
      <span class="label">[STEP 1]</span>
      <code>/plugin marketplace add unqdlphn/quirgs</code>
      <button
        class="copy-btn"
        onclick="navigator.clipboard.writeText('/plugin marketplace add unqdlphn/quirgs'); const btn = this; btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000);"
      >
        Copy
      </button>
    </p>
    <p class="install-cmd-row">
      <span class="label">[STEP 2]</span>
      <code>/plugin install quirgs-compliance@quirgs</code>
      <button
        class="copy-btn"
        onclick="navigator.clipboard.writeText('/plugin install quirgs-compliance@quirgs'); const btn = this; btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000);"
      >
        Copy
      </button>
    </p>
  </div>
  <div class="line">&nbsp;</div>
  <div class="line">
    <span class="prompt">admin@quirgs</span><span class="path">~/install</span
    ><span class="text-bright">$&nbsp;</span><span class="cursor"></span>
  </div>
</BaseLayout>

<style>
  /* Contents block: single div, no inter-line margin gaps */
  .bundle-contents {
    align-items: flex-start;
  }

  .contents-list {
    line-height: 1.55;
  }

  /* Suppress the dashed underline on skill links inside the contents block only */
  .contents-list a {
    border-bottom: none;
  }

  .contents-list a:hover {
    border-bottom: 1px dashed var(--accent-green);
  }
</style>
