---
// src/layouts/BaseLayout.astro
import HelpModal from "../components/HelpModal.astro";
import SiteMenu from "../components/SiteMenu.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  terminalPath?: string;
}

const { title, description, terminalPath = "~" } = Astro.props;

// Normalized current path for SiteMenu's "(you are here)" marker.
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

// Self-referencing canonical. Without it Google self-selects, which previously
// let chatgpt.com be credited as canonical for legacy guides. Derived from the
// configured `site` (https://quirgs.com) so it's absolute and query-string-free.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <style is:global>
      :root {
        --bg-color: #09090b;
        --term-bg: #18181b;
        --term-border: #27272a;
        --text-main: #a1a1aa;
        --text-bright: #f4f4f5;
        --accent-green: #4ade80;
        --accent-blue: #60a5fa;
        --accent-red: #f87171;
        --accent-yellow: #facc15;
      }

      body {
        background-color: var(--bg-color);
        color: var(--text-main);
        font-family: "JetBrains Mono", "Courier New", Courier, monospace;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh;
        min-height: 100dvh;
        margin: 0;
        padding: 20px;
        box-sizing: border-box;
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }

      .main-wrapper {
        width: 100%;
        max-width: 800px;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        margin: auto 0;
      }

      .logo {
        width: 96px;
        margin-top: 0;
        flex-shrink: 0;
      }

      .site-bottom-row {
        width: 100%;
        max-width: 800px;
        margin-top: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      @media (max-width: 600px) {
        .logo {
          width: 64px;
        }
        .site-bottom-row {
          margin-top: 16px;
          gap: 8px;
        }
      }

      .terminal-container {
        width: 100%;
        max-width: 800px;
        background-color: var(--term-bg);
        border: 1px solid var(--term-border);
        border-radius: 8px;
        box-shadow:
          0 20px 50px rgba(0, 0, 0, 0.5),
          0 0 30px rgba(74, 222, 128, 0.2);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 120px);
        max-height: calc(100dvh - 120px);
      }

      .terminal-header {
        background-color: #09090b;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--term-border);
      }

      .mac-btns {
        display: flex;
        gap: 8px;
      }

      .mac-btn {
        width: 12px;
        height: 12px;
        border-radius: 50%;
      }

      .close {
        background-color: #ff5f56;
      }

      .minimize {
        background-color: #ffbd2e;
      }

      .maximize {
        background-color: #27c93f;
      }

      .terminal-title {
        flex-grow: 1;
        text-align: center;
        color: #a1a1aa;
        font-size: 0.85rem;
        /* no right margin — help-trigger sits to the right instead */
      }

      /* [?] help trigger button in the terminal header */
      .help-trigger {
        background: transparent;
        border: 1px solid var(--term-border);
        color: #a1a1aa;
        font-family: "JetBrains Mono", "Courier New", Courier, monospace;
        font-size: 0.75rem;
        padding: 2px 6px;
        cursor: pointer;
        border-radius: 3px;
        transition:
          color 0.15s,
          border-color 0.15s;
        flex-shrink: 0;
        line-height: 1;
      }

      .help-trigger:hover {
        color: var(--accent-blue);
        border-color: var(--accent-blue);
      }

      .help-trigger + .help-trigger {
        margin-left: 8px;
      }

      .terminal-body {
        padding: 24px;
        font-size: 0.95rem;
        line-height: 1.6;
        min-height: min(400px, 60vh);
        min-height: min(400px, 60dvh);
        overflow-y: auto;
      }

      .line {
        margin-bottom: 8px;
        display: flex;
        flex-wrap: wrap;
        white-space: pre-wrap;
      }

      /* Tighter line spacing for continuation rows (e.g. bundle contents list) */
      .line-tight {
        margin-bottom: 2px;
      }

      .prompt {
        color: var(--accent-green);
        margin-right: 8px;
        font-weight: bold;
      }

      .path {
        color: var(--accent-blue);
        margin-right: 8px;
      }

      .text-red {
        color: var(--accent-red);
        margin-right: 0px;
      }

      .text-yellow {
        color: var(--accent-yellow);
        margin-right: 0px;
      }

      .text-blue {
        color: var(--accent-blue);
        margin-right: 0px;
      }

      .text-green {
        color: var(--accent-green);
        margin-right: 0px;
      }

      .text-bright {
        color: var(--text-bright);
        margin-right: 0px;
      }

      /* Blinking cursor */
      .cursor {
        display: inline-block;
        width: 10px;
        height: 1.2em;
        background-color: var(--text-bright);
        vertical-align: bottom;
        animation: blink 1s step-end infinite;
        margin-left: 2px;
      }

      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0;
        }
      }

      /* Inline tag — yellow bordered pill used in terminal listings */
      .tag {
        color: var(--accent-yellow);
        border: 1px solid var(--accent-yellow);
        padding: 0px 6px;
        border-radius: 3px;
        font-size: 0.8rem;
        margin-left: 8px;
        display: inline-block;
        line-height: 1.4;
      }

      a {
        color: var(--accent-blue);
        text-decoration: none;
        border-bottom: 1px dashed var(--accent-blue);
        transition:
          color 0.2s,
          border-color 0.2s;
      }

      a:hover {
        color: var(--accent-green);
        border-color: var(--accent-green);
      }

      /* Detail page styling */
      .detail-header {
        margin-bottom: 24px;
        border-bottom: 1px dashed var(--term-border);
        padding-bottom: 16px;
      }

      .detail-header h1 {
        font-size: 1.5rem;
        margin: 0 0 8px 0;
        color: var(--text-bright);
      }

      .detail-header .tagline {
        font-size: 1.05rem;
        color: var(--text-main);
        margin: 0 0 12px 0;
      }

      .badges-row {
        display: flex;
        gap: 12px;
      }

      .badge {
        font-size: 0.8rem;
        padding: 2px 8px;
        border-radius: 4px;
        border: 1px solid var(--term-border);
        background: rgba(255, 255, 255, 0.05);
      }

      .status-badge.status-live {
        color: var(--accent-green);
        border-color: rgba(74, 222, 128, 0.3);
        background: rgba(74, 222, 128, 0.05);
      }

      .status-badge.status-draft {
        color: var(--accent-yellow);
        border-color: rgba(250, 204, 21, 0.3);
        background: rgba(250, 204, 21, 0.05);
      }

      .status-badge.status-deprecated {
        color: var(--accent-red);
        border-color: rgba(248, 113, 113, 0.3);
        background: rgba(248, 113, 113, 0.05);
      }

      .detail-footer {
        margin-top: 32px;
        padding-top: 16px;
        border-top: 1px dashed var(--term-border);
        font-size: 0.85rem;
      }

      .detail-footer p {
        margin: 6px 0;
      }

      .detail-footer .label {
        color: var(--text-bright);
        font-weight: bold;
        display: inline-block;
        width: 140px;
      }

      .install-block {
        margin: 24px 0;
        padding: 16px;
        background: rgba(96, 165, 250, 0.05);
        border: 1px solid rgba(96, 165, 250, 0.2);
        border-radius: 6px;
      }

      .install-block p {
        margin: 8px 0;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
      }

      /* install-cmd-row: command + copy button row inside .install-block */
      .install-cmd-row {
        gap: 10px;
      }

      .install-block .label {
        color: var(--accent-blue);
        font-weight: bold;
        margin-right: 12px;
      }

      .install-block code {
        background: #09090b;
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid var(--term-border);
        color: var(--text-bright);
        font-family: inherit;
        word-break: break-all;
        overflow-wrap: anywhere;
        min-width: 0;
      }

      .copy-btn {
        background: transparent;
        border: 1px solid var(--accent-blue);
        color: var(--accent-blue);
        padding: 2px 8px;
        font-size: 0.75rem;
        font-family: inherit;
        cursor: pointer;
        border-radius: 4px;
        margin-left: 12px;
        transition: all 0.2s;
      }

      .copy-btn:hover {
        background: rgba(96, 165, 250, 0.1);
        color: var(--text-bright);
      }

      /* ── /review/ HITL Gate queue ───────────────────────────────── */
      /* These live in the global layout (not a page-scoped block on     */
      /* review.astro) because review.js builds the event cards and      */
      /* Approve/Reject buttons via innerHTML at runtime. JS-injected     */
      /* nodes never receive Astro's scoped data-astro-* hash, so a       */
      /* scoped block would leave them with browser-default styling.      */
      .divider {
        color: var(--term-border);
        user-select: none;
      }

      .token-block {
        border: 1px dashed var(--term-border);
        padding: 16px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.01);
      }

      .token-input-row {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
      }

      .terminal-input {
        background: #09090b;
        border: 1px solid var(--term-border);
        color: var(--text-bright);
        font-family: inherit;
        font-size: 0.9rem;
        padding: 6px 12px;
        border-radius: 4px;
        width: 320px;
        max-width: 100%;
        outline: none;
        transition: border-color 0.2s;
      }

      .terminal-input:focus {
        border-color: var(--accent-blue);
      }

      /* Bracketed terminal button — same language as .copy-btn / .help-trigger */
      .terminal-btn {
        background: transparent;
        border: 1px solid var(--accent-blue);
        color: var(--accent-blue);
        padding: 6px 12px;
        font-size: 0.9rem;
        font-family: inherit;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
      }

      .terminal-btn:hover {
        background: rgba(96, 165, 250, 0.1);
        color: var(--text-bright);
      }

      /* Cards (review.js + demo.js) separate with a CSS rule, not a glyph
         divider. A "━"×39 run is a single unbreakable token wider than a phone
         viewport and overflowed horizontally; a border can never overflow. */
      .event-card {
        margin-bottom: 24px;
        border-top: 1px solid var(--term-border);
        padding-top: 16px;
      }

      .event-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        max-width: 400px;
      }

      .card-actions {
        display: flex;
        gap: 16px;
        margin-top: 12px;
      }

      /* Approve / Reject — TUI buttons: transparent fill, accent border,    */
      /* bracketed label, hover wash. Green = approve, red = reject.         */
      .action-btn {
        background: transparent;
        border: 1px solid;
        padding: 4px 10px;
        font-size: 0.85rem;
        font-family: inherit;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
      }

      .approve-btn {
        border-color: var(--accent-green);
        color: var(--accent-green);
      }

      .approve-btn:hover:not(:disabled) {
        background: rgba(74, 222, 128, 0.1);
        color: var(--text-bright);
      }

      .reject-btn {
        border-color: var(--accent-red);
        color: var(--accent-red);
      }

      .reject-btn:hover:not(:disabled) {
        background: rgba(248, 113, 113, 0.1);
        color: var(--text-bright);
      }

      .action-btn:disabled {
        border-color: var(--term-border) !important;
        color: var(--text-main) !important;
        opacity: 0.5;
        cursor: not-allowed;
        background: transparent !important;
      }

      .error-line {
        font-weight: bold;
      }

      .archive-note {
        margin-top: 24px;
        padding: 16px;
        border-left: 3px solid var(--accent-yellow);
        background: rgba(250, 204, 21, 0.03);
        font-size: 0.9rem;
        line-height: 1.5;
      }

      /* MDX content typography inside terminal body */
      .terminal-body h2 {
        font-size: 1.15rem;
        color: var(--text-bright);
        margin: 24px 0 12px 0;
        border-bottom: 1px solid var(--term-border);
        padding-bottom: 6px;
      }

      .terminal-body h3 {
        font-size: 1.05rem;
        color: var(--text-bright);
        margin: 20px 0 10px 0;
      }

      .terminal-body p {
        margin: 0 0 12px 0;
        line-height: 1.6;
      }

      .terminal-body ul,
      .terminal-body ol {
        margin: 0 0 16px 0;
        padding-left: 24px;
      }

      .terminal-body li {
        margin-bottom: 6px;
      }

      .terminal-body code {
        color: var(--accent-green);
        background: #09090b;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
        border: 1px solid var(--term-border);
        font-family: inherit;
      }

      .terminal-body pre {
        background: #09090b;
        border: 1px solid var(--term-border);
        border-radius: 6px;
        padding: 16px;
        overflow-x: auto;
        margin: 16px 0;
        font-family: inherit;
      }

      .terminal-body pre code {
        background: none;
        border: none;
        padding: 0;
        color: var(--text-bright);
        font-size: 0.9rem;
      }

      /* MDX tables (e.g. command-reference guides). Skills don't use tables;    */
      /* guides are the first MDX content that does, so these live here.         */
      .terminal-body table {
        width: 100%;
        border-collapse: collapse;
        margin: 16px 0;
        font-size: 0.9rem;
      }

      .terminal-body th,
      .terminal-body td {
        border: 1px solid var(--term-border);
        padding: 8px 12px;
        text-align: left;
        vertical-align: top;
      }

      .terminal-body th {
        color: var(--text-bright);
        background: rgba(255, 255, 255, 0.03);
        font-weight: bold;
      }

      /* ── Large-screen 16:9 layout ───────────────────────────────── */
      /* At ≥1280px viewport, the terminal window grows to 1280px wide  */
      /* and locks to a 16:9 aspect ratio. Content scrolls inside the  */
      /* terminal-body as before; the outer window stays cinematic.    */
      @media (min-width: 1280px) {
        .main-wrapper {
          max-width: 1280px;
        }

        .site-bottom-row {
          max-width: 1280px;
        }

        .terminal-container {
          max-width: 1280px;
          aspect-ratio: 16 / 9;
          /* max-height still applies; at 1280px wide 16:9 = 720px which   */
          /* is well within calc(100dvh - 120px) on any modern display.   */
        }
      }
    </style>
  </head>
  <body>
    <main class="main-wrapper">
      <div class="terminal-container">
        <div class="terminal-header">
          <div class="mac-btns">
            <div class="mac-btn close"></div>
            <div class="mac-btn minimize"></div>
            <div class="mac-btn maximize"></div>
          </div>
          <div class="terminal-title">
            admin@quirgs: {terminalPath}
          </div>
          <button
            class="help-trigger menu-trigger"
            aria-label="Open site menu"
            title="Site map">[≡]</button
          >
          <button
            id="help-open-btn"
            class="help-trigger"
            aria-label="Open help"
            title="How Quirgs works">[?]</button
          >
        </div>
        <div class="terminal-body">
          <slot />
        </div>
      </div>
      <div class="site-bottom-row">
        <Footer />
        <img src="/assets/logo.png" alt="Quirgs Logo" class="logo" />
      </div>
    </main>
    <HelpModal />
    <SiteMenu currentPath={currentPath} />

    <script>
      // Delegated copy-to-clipboard for [data-copy] buttons.
      // Replaces inline onclick handlers so the CSP needs no 'unsafe-inline'
      // / 'unsafe-hashes' for script-src.
      document.addEventListener("click", (event) => {
        const target = event.target as HTMLElement;
        const btn = target.closest<HTMLButtonElement>(".copy-btn[data-copy]");
        if (!btn) return;
        const text = btn.dataset.copy ?? "";
        navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(() => {
          btn.textContent = original;
        }, 2000);
      });
    </script>
  </body>
</html>
