---
// src/layouts/BaseLayout.astro
interface Props {
    title: string;
    description: string;
    terminalPath?: string;
}

const { title, description, terminalPath = "~" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover"
        />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="icon" href="/favicon.ico" sizes="48x48" />
        <link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml" />
        <link rel="apple-touch-icon" href="/favicon.svg" />

        <style is:global>
            :root {
                --bg-color: #09090b;
                --term-bg: #18181b;
                --term-border: #27272a;
                --text-main: #a1a1aa;
                --text-bright: #f4f4f5;
                --accent-green: #4ade80;
                --accent-blue: #60a5fa;
                --accent-red: #f87171;
                --accent-yellow: #facc15;
            }

            body {
                background-color: var(--bg-color);
                color: var(--text-main);
                font-family: "JetBrains Mono", "Courier New", Courier, monospace;
                display: flex;
                flex-direction: column;
                align-items: center;
                min-height: 100vh;
                min-height: 100dvh;
                margin: 0;
                padding: 20px;
                box-sizing: border-box;
            }

            .main-wrapper {
                width: 100%;
                max-width: 800px;
                display: flex;
                flex-direction: column;
                align-items: flex-end;
                margin: auto 0;
            }

            .logo {
                width: 96px;
                margin-top: 32px;
            }

            .terminal-container {
                width: 100%;
                max-width: 800px;
                background-color: var(--term-bg);
                border: 1px solid var(--term-border);
                border-radius: 8px;
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
                overflow: hidden;
                display: flex;
                flex-direction: column;
                max-height: calc(100vh - 120px);
                max-height: calc(100dvh - 120px);
            }

            .terminal-header {
                background-color: #09090b;
                padding: 12px 16px;
                display: flex;
                align-items: center;
                border-bottom: 1px solid var(--term-border);
            }

            .mac-btns {
                display: flex;
                gap: 8px;
            }

            .mac-btn {
                width: 12px;
                height: 12px;
                border-radius: 50%;
            }

            .close {
                background-color: #ff5f56;
            }

            .minimize {
                background-color: #ffbd2e;
            }

            .maximize {
                background-color: #27c93f;
            }

            .terminal-title {
                flex-grow: 1;
                text-align: center;
                color: #71717a;
                font-size: 0.85rem;
                margin-right: 60px; /* offset for buttons to keep text centered */
            }

            .terminal-body {
                padding: 24px;
                font-size: 0.95rem;
                line-height: 1.6;
                min-height: min(400px, 60vh);
                min-height: min(400px, 60dvh);
                overflow-y: auto;
            }

            .line {
                margin-bottom: 8px;
                display: flex;
                flex-wrap: wrap;
                white-space: pre-wrap;
            }

            .prompt {
                color: var(--accent-green);
                margin-right: 8px;
                font-weight: bold;
            }

            .path {
                color: var(--accent-blue);
                margin-right: 8px;
            }

            .text-red {
                color: var(--accent-red);
                margin-right: 0px;
            }

            .text-yellow {
                color: var(--accent-yellow);
                margin-right: 0px;
            }

            .text-blue {
                color: var(--accent-blue);
                margin-right: 0px;
            }

            .text-green {
                color: var(--accent-green);
                margin-right: 0px;
            }

            .text-bright {
                color: var(--text-bright);
                margin-right: 0px;
            }

            /* Blinking cursor */
            .cursor {
                display: inline-block;
                width: 10px;
                height: 1.2em;
                background-color: var(--text-bright);
                vertical-align: bottom;
                animation: blink 1s step-end infinite;
                margin-left: 2px;
            }

            @keyframes blink {
                0%, 100% { opacity: 1; }
                50%       { opacity: 0; }
            }

            /* Inline tag — yellow bordered pill used in terminal listings */
            .tag {
                color: var(--accent-yellow);
                border: 1px solid var(--accent-yellow);
                padding: 0px 6px;
                border-radius: 3px;
                font-size: 0.8rem;
                margin-left: 8px;
                display: inline-block;
                line-height: 1.4;
            }

            a {
                color: var(--accent-blue);
                text-decoration: none;
                border-bottom: 1px dashed var(--accent-blue);
                transition: color 0.2s, border-color 0.2s;
            }

            a:hover {
                color: var(--accent-green);
                border-color: var(--accent-green);
            }

            /* Detail page styling */
            .detail-header {
                margin-bottom: 24px;
                border-bottom: 1px dashed var(--term-border);
                padding-bottom: 16px;
            }

            .detail-header h1 {
                font-size: 1.5rem;
                margin: 0 0 8px 0;
                color: var(--text-bright);
            }

            .detail-header .tagline {
                font-size: 1.05rem;
                color: var(--text-main);
                margin: 0 0 12px 0;
            }

            .badges-row {
                display: flex;
                gap: 12px;
            }

            .badge {
                font-size: 0.8rem;
                padding: 2px 8px;
                border-radius: 4px;
                border: 1px solid var(--term-border);
                background: rgba(255, 255, 255, 0.05);
            }

            .status-badge.status-live {
                color: var(--accent-green);
                border-color: rgba(74, 222, 128, 0.3);
                background: rgba(74, 222, 128, 0.05);
            }

            .status-badge.status-draft {
                color: var(--accent-yellow);
                border-color: rgba(250, 204, 21, 0.3);
                background: rgba(250, 204, 21, 0.05);
            }

            .status-badge.status-deprecated {
                color: var(--accent-red);
                border-color: rgba(248, 113, 113, 0.3);
                background: rgba(248, 113, 113, 0.05);
            }

            .detail-footer {
                margin-top: 32px;
                padding-top: 16px;
                border-top: 1px dashed var(--term-border);
                font-size: 0.85rem;
            }

            .detail-footer p {
                margin: 6px 0;
            }

            .detail-footer .label {
                color: var(--text-bright);
                font-weight: bold;
                display: inline-block;
                width: 140px;
            }

            .install-block {
                margin: 24px 0;
                padding: 16px;
                background: rgba(96, 165, 250, 0.05);
                border: 1px solid rgba(96, 165, 250, 0.2);
                border-radius: 6px;
            }

            .install-block p {
                margin: 8px 0;
                display: flex;
                align-items: center;
                flex-wrap: wrap;
            }

            /* install-cmd-row: command + copy button row inside .install-block */
            .install-cmd-row {
                gap: 10px;
            }

            .install-block .label {
                color: var(--accent-blue);
                font-weight: bold;
                margin-right: 12px;
            }

            .install-block code {
                background: #09090b;
                padding: 4px 8px;
                border-radius: 4px;
                border: 1px solid var(--term-border);
                color: var(--text-bright);
                font-family: inherit;
            }

            .copy-btn {
                background: transparent;
                border: 1px solid var(--accent-blue);
                color: var(--accent-blue);
                padding: 2px 8px;
                font-size: 0.75rem;
                font-family: inherit;
                cursor: pointer;
                border-radius: 4px;
                margin-left: 12px;
                transition: all 0.2s;
            }

            .copy-btn:hover {
                background: rgba(96, 165, 250, 0.1);
                color: var(--text-bright);
            }

            .archive-note {
                margin-top: 24px;
                padding: 16px;
                border-left: 3px solid var(--accent-yellow);
                background: rgba(250, 204, 21, 0.03);
                font-size: 0.9rem;
                line-height: 1.5;
            }

            /* MDX content typography inside terminal body */
            .terminal-body h2 {
                font-size: 1.15rem;
                color: var(--text-bright);
                margin: 24px 0 12px 0;
                border-bottom: 1px solid var(--term-border);
                padding-bottom: 6px;
            }

            .terminal-body h3 {
                font-size: 1.05rem;
                color: var(--text-bright);
                margin: 20px 0 10px 0;
            }

            .terminal-body p {
                margin: 0 0 12px 0;
                line-height: 1.6;
            }

            .terminal-body ul,
            .terminal-body ol {
                margin: 0 0 16px 0;
                padding-left: 24px;
            }

            .terminal-body li {
                margin-bottom: 6px;
            }

            .terminal-body code {
                color: var(--accent-green);
                background: #09090b;
                padding: 2px 6px;
                border-radius: 4px;
                font-size: 0.9em;
                border: 1px solid var(--term-border);
                font-family: inherit;
            }

            .terminal-body pre {
                background: #09090b;
                border: 1px solid var(--term-border);
                border-radius: 6px;
                padding: 16px;
                overflow-x: auto;
                margin: 16px 0;
                font-family: inherit;
            }

            .terminal-body pre code {
                background: none;
                border: none;
                padding: 0;
                color: var(--text-bright);
                font-size: 0.9rem;
            }
        </style>
    </head>
    <body>
        <div class="main-wrapper">
            <div class="terminal-container">
                <div class="terminal-header">
                    <div class="mac-btns">
                        <div class="mac-btn close"></div>
                        <div class="mac-btn minimize"></div>
                        <div class="mac-btn maximize"></div>
                    </div>
                    <div class="terminal-title">
                        admin@quirgs: {terminalPath}
                    </div>
                </div>
                <div class="terminal-body">
                    <slot />
                </div>
            </div>
            <img src="/assets/logo.png" alt="Quirgs Logo" class="logo" />
        </div>
    </body>
</html>
