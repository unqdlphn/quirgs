---
// src/components/SiteMenu.astro
// Terminal-themed full sitemap overlay — the scalable navigation surface.
// Renders every route from src/data/routes.ts as a grouped `tree` listing,
// so new pages/groups add a line here instead of a line on every page.
//
// Triggered by any element with class "menu-trigger" (the [≡] button in
// BaseLayout's terminal header, and NavBlock's [+N more] token).
// Dismissed by clicking the backdrop, pressing Escape, or clicking [×].
//
// Included once in BaseLayout — available on every page that uses it.

import { routesByGroup, routes } from "../data/routes";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const rootRoute = routes.find((r) => r.path === "/");

// Root (`/`) renders as the tree's top line, not as a group member.
const grouped = routesByGroup
  .map(({ group, routes }) => ({
    group,
    routes: routes.filter((r) => r.path !== "/"),
  }))
  .filter((g) => g.routes.length > 0);

const maxLabel = Math.max(
  ...grouped.flatMap((g) => g.routes.map((r) => r.label.length)),
);
const pad = (label: string) => " ".repeat(maxLabel + 2 - label.length);
---

<!-- Sitemap overlay backdrop -->
<div
  id="site-menu-backdrop"
  class="menu-backdrop"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
>
  <div class="menu-terminal">
    <!-- Header bar -->
    <div class="menu-header">
      <div class="mac-btns">
        <div class="mac-btn close"></div>
        <div class="mac-btn minimize"></div>
        <div class="mac-btn maximize"></div>
      </div>
      <div class="menu-title">admin@quirgs: ~/sitemap</div>
      <button
        id="site-menu-close"
        class="menu-close"
        aria-label="Close site menu">[×]</button
      >
    </div>

    <!-- Body -->
    <nav class="menu-body" aria-label="Full site navigation">
      <div class="menu-line">
        <span class="prompt">admin@quirgs</span><span class="path">~/</span
        ><span class="text-bright">$</span>&nbsp;tree --dirsfirst ~
      </div>
      <div class="menu-line">&nbsp;</div>
      <div class="menu-line menu-tree">
        {
          rootRoute && rootRoute.path === currentPath ? (
            <span class="menu-current" aria-current="page">
              /
            </span>
          ) : (
            <a href="/">/</a>
          )
        }
      </div>
      {
        grouped.map((g, gi) => {
          const lastGroup = gi === grouped.length - 1;
          const groupBranch = lastGroup ? "└── " : "├── ";
          const childIndent = lastGroup ? "    " : "│   ";
          return (
            <>
              <div class="menu-line menu-tree">
                <span class="menu-branch">{groupBranch}</span>
                <span class="menu-group">{g.group}</span>
              </div>
              {g.routes.map((r, ri) => {
                const lastRoute = ri === g.routes.length - 1;
                const branch = childIndent + (lastRoute ? "└── " : "├── ");
                const isCurrent = r.path === currentPath;
                return (
                  <div class="menu-line menu-tree">
                    <span class="menu-branch">{branch}</span>
                    {isCurrent ? (
                      <span class="menu-current" aria-current="page">
                        {r.label}
                      </span>
                    ) : (
                      <a href={r.path}>{r.label}</a>
                    )}
                    <span class="menu-pad">{pad(r.label)}</span>
                    <span class="menu-desc">
                      {isCurrent ? "(you are here)" : `← ${r.description}`}
                    </span>
                  </div>
                );
              })}
            </>
          );
        })
      }
      <div class="menu-line">&nbsp;</div>
      <div class="menu-line">
        <span class="prompt">admin@quirgs</span><span class="path"
          >~/sitemap</span
        ><span class="text-bright">$</span>&nbsp;<span class="cursor"></span>
      </div>
    </nav>
  </div>
</div>

<style>
  .menu-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
  }

  .menu-backdrop.open {
    display: flex;
  }

  .menu-terminal {
    width: 100%;
    max-width: 560px;
    max-height: 85vh;
    background-color: var(--term-bg);
    border: 1px solid var(--term-border);
    border-radius: 8px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    animation: modal-in 0.15s ease-out;
  }

  @keyframes modal-in {
    from {
      opacity: 0;
      transform: translateY(-12px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .menu-header {
    background-color: #09090b;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--term-border);
    flex-shrink: 0;
  }

  .menu-title {
    flex-grow: 1;
    text-align: center;
    color: #71717a;
    font-size: 0.85rem;
    font-family: "JetBrains Mono", "Courier New", Courier, monospace;
  }

  .menu-close {
    background: transparent;
    border: 1px solid var(--term-border);
    color: #71717a;
    font-family: "JetBrains Mono", "Courier New", Courier, monospace;
    font-size: 0.8rem;
    padding: 2px 6px;
    cursor: pointer;
    border-radius: 3px;
    transition:
      color 0.15s,
      border-color 0.15s;
    line-height: 1;
  }

  .menu-close:hover {
    color: var(--accent-red, #f87171);
    border-color: var(--accent-red, #f87171);
  }

  .menu-body {
    padding: 20px 24px;
    font-size: 0.9rem;
    line-height: 1.6;
    font-family: "JetBrains Mono", "Courier New", Courier, monospace;
    color: var(--text-main);
    overflow-y: auto;
  }

  .menu-line {
    margin-bottom: 4px;
    display: flex;
    align-items: baseline;
  }

  .menu-tree,
  .menu-branch,
  .menu-pad {
    white-space: pre;
  }

  .menu-branch {
    color: #3f3f46;
  }

  .menu-group {
    color: var(--accent-yellow);
    letter-spacing: 0.04em;
  }

  .menu-current {
    color: var(--text-bright);
    font-weight: bold;
  }

  .menu-desc {
    color: #71717a;
  }

  .menu-body .prompt {
    color: var(--accent-green);
    margin-right: 8px;
    font-weight: bold;
  }
  .menu-body .path {
    color: var(--accent-blue);
    margin-right: 8px;
  }
  .menu-body .text-bright {
    color: var(--text-bright);
  }

  .menu-body a {
    color: var(--accent-blue);
    text-decoration: none;
    border-bottom: 1px dashed var(--accent-blue);
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .menu-body a:hover {
    color: var(--accent-green);
    border-color: var(--accent-green);
  }

  .menu-body .cursor {
    display: inline-block;
    width: 10px;
    height: 1.2em;
    background-color: var(--text-bright);
    vertical-align: bottom;
    animation: blink 1s step-end infinite;
    margin-left: 2px;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 600px) {
    .menu-pad,
    .menu-desc {
      display: none;
    }
  }
</style>

<script>
  const backdrop = document.getElementById("site-menu-backdrop");
  const closeBtn = document.getElementById("site-menu-close");

  let lastTrigger: HTMLElement | null = null;

  function openMenu(trigger: HTMLElement) {
    lastTrigger = trigger;
    backdrop?.classList.add("open");
    backdrop?.removeAttribute("aria-hidden");
    closeBtn?.focus();
  }

  function closeMenu() {
    backdrop?.classList.remove("open");
    backdrop?.setAttribute("aria-hidden", "true");
    lastTrigger?.focus();
  }

  // Delegated open — any .menu-trigger (header [≡], NavBlock [+N more]).
  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;
    const trigger = target.closest<HTMLElement>(".menu-trigger");
    if (trigger) openMenu(trigger);
  });

  closeBtn?.addEventListener("click", closeMenu);

  // Click outside the terminal window to close
  backdrop?.addEventListener("click", (e) => {
    if (e.target === backdrop) closeMenu();
  });

  // Escape key to close
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && backdrop?.classList.contains("open")) {
      closeMenu();
    }
  });
</script>
